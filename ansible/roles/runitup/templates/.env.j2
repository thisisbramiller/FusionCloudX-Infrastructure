# Run It Up runtime environment — SQLite-backed (no external DB).
NODE_ENV=production
TZ={{ runitup_timezone }}
PORT={{ runitup_container_port }}
BASE_URL=https://{{ ansible_host }}:{{ runitup_https_port }}
# SQLite database file lives on the runitup-data named volume (mounted at /app/data).
DATABASE_URL=file:/app/data/runitup.db

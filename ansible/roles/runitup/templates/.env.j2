# Run It Up runtime environment — SQLite-backed (no external DB).
NODE_ENV=production
TZ={{ runitup_timezone }}
PORT={{ runitup_container_port }}
BASE_URL=https://{{ inventory_hostname }}.fusioncloudx.home:{{ runitup_https_port }}
# SQLite database file lives on the runitup-data named volume (mounted at /data,
# matching the app's Dockerfile default RUNITUP_DB=/data/runitup.db).
RUNITUP_DB=/data/runitup.db

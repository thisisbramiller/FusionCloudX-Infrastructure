---
services:
  app:
    build:
      # App source is synced to {{ runitup_app_dir }} by the runitup role.
      # The app's own multi-stage Dockerfile does the build.
      context: ./app
    container_name: runitup
    restart: always
    env_file:
      - .env
    volumes:
      # SQLite data on a named volume, bind-backed to the host data dir so the
      # backup-client can export it under {{ runitup_compose_dir }}.
      - runitup-data:/app/data

  nginx:
    image: {{ runitup_nginx_image }}
    container_name: runitup-nginx
    restart: always
    ports:
      - "{{ runitup_https_port }}:443"
    depends_on:
      - app
    volumes:
      - {{ runitup_ssl_cert }}:/etc/nginx/ssl/server.crt:ro
      - {{ runitup_ssl_key }}:/etc/nginx/ssl/server.key:ro
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro

volumes:
  runitup-data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ runitup_data_dir }}
